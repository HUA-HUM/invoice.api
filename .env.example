PORT=3000
HOST=127.0.0.1
INVOICE_INTERNAL_API_KEY=

XUBIO_BASE_URL=https://xubio.com
XUBIO_BASIC_AUTHORIZATION=
XUBIO_COMPROBANTES_LIST_LIMIT=100
XUBIO_REQUEST_RETRY_ATTEMPTS=4
XUBIO_REQUEST_RETRY_INITIAL_DELAY_MS=1000
XUBIO_REQUEST_RETRY_MAX_DELAY_MS=10000

MADRE_API_BASE_URL=https://api.madre.loquieroaca.com
MADRE_INTERNAL_API_KEY=

# Redis / BullMQ
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_USERNAME=
# REDIS_PASSWORD=
# REDIS_TLS=false

# Xubio comprobantes queue
XUBIO_COMPROBANTES_QUEUE_CONCURRENCY=1
XUBIO_COMPROBANTES_QUEUE_ATTEMPTS=3
XUBIO_COMPROBANTES_QUEUE_RETRY_DELAY_MS=30000
XUBIO_COMPROBANTES_QUEUE_REMOVE_COMPLETE_COUNT=1000
XUBIO_COMPROBANTES_QUEUE_REMOVE_FAIL_COUNT=1000

# Stock BUE TLQV cache
STOCK_BUE_TLQV_CACHE_KEY_PREFIX=invoice-api:stock-bue:tlqv
STOCK_BUE_TLQV_CACHE_PAGE_SIZE=100
STOCK_BUE_TLQV_CACHE_CRON_ENABLED=true
# Dos veces por dia. Interpreta el cron segun timezone del servidor.
STOCK_BUE_TLQV_CACHE_REFRESH_CRON=0 3,15 * * *
STOCK_BUE_TLQV_CACHE_QUEUE_CONCURRENCY=1
STOCK_BUE_TLQV_CACHE_QUEUE_ATTEMPTS=3
STOCK_BUE_TLQV_CACHE_QUEUE_RETRY_DELAY_MS=30000
STOCK_BUE_TLQV_CACHE_QUEUE_REMOVE_COMPLETE_COUNT=1000
STOCK_BUE_TLQV_CACHE_QUEUE_REMOVE_FAIL_COUNT=1000

# Bull Board
BULL_BOARD_ENABLED=true
BULL_BOARD_BASE_PATH=/admin/queues
